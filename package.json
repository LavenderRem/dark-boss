{
  "name": "dark-boss",
  "version": "0.1.0",
  "private": true,
  "description": "暗黑老板 - 图形化 Claude Code 多 Agent 编排平台",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"pnpm --filter @dark-boss/server dev\" \"pnpm --filter @dark-boss/client dev\"",
    "dev:server": "pnpm --filter @dark-boss/server dev",
    "dev:client": "pnpm --filter @dark-boss/client dev",
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "db:generate": "pnpm --filter @dark-boss/server db:generate",
    "db:migrate": "pnpm --filter @dark-boss/server db:migrate",
    "db:seed": "pnpm --filter @dark-boss/server db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
