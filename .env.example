# Dark Boss 环境配置

# 服务端口
PORT=3000

# 服务主机
HOST=localhost

# 前端开发服务器端口
CLIENT_PORT=5173

# 运行环境: development | production
NODE_ENV=development

# 数据存储目录
DATA_DIR=~/.dark-boss

# Claude API 配置（支持智谱等兼容 API）
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=

# 模型配置
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-20250414
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-20250414
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-20250414

# API 超时时间（毫秒），默认 50 分钟
API_TIMEOUT_MS=3000000
