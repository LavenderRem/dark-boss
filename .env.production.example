# Dark Boss 生产环境配置示例
# 复制此文件为 .env.production 并填入实际值

# 服务端口（生产环境保持默认）
PORT=3001
HOST=0.0.0.0

# 运行环境
NODE_ENV=production

# 数据存储目录
DATA_DIR=/var/data/dark-boss

# Claude API 配置（必填）
ANTHROPIC_AUTH_TOKEN=sk-ant-xxxxx
ANTHROPIC_BASE_URL=

# 模型配置
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-20250414
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-20250414
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-20250414

# API 超时时间（毫秒）
API_TIMEOUT_MS=3000000
