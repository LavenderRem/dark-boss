# Dark Boss 生产环境配置

# 服务端口
PORT=3000

# 服务主机（Docker 内必须 0.0.0.0）
HOST=0.0.0.0

# 运行环境
NODE_ENV=production

# 数据存储目录
DATA_DIR=/root/.dark-boss

# Claude API 配置
ANTHROPIC_AUTH_TOKEN=你的token
ANTHROPIC_BASE_URL=你的API地址

# 模型配置
ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-20250414
ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-20250414
ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-20250414

# API 超时（毫秒）
API_TIMEOUT_MS=3000000
